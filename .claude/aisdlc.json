{
  "_comment": "AISDLC workflow + harness config. State / category / override vocabularies are documented in .claude/skills/README.md (structural, not project-tunable).",

  "branches": {
    "prefix": "claude/",
    "protected": ["main", "master", "stage", "production"]
  },

  "paths": {
    "feature":   "docs/features/{feature-slug}.md",
    "manifest":  "docs/ai-runs/{feature-slug}/manifest.yaml",
    "runs":      "docs/ai-runs/{feature-slug}/{story-id}/",
    "worktrees": ".worktrees/{story-id}/"
  },

  "caps": {
    "tddAttempts":          3,
    "diffFiles":            80,
    "diffLines":            3000,
    "perStoryWallClockSec": 3600,
    "afk": {
      "maxFlows":     10,
      "wallClockSec": 300
    }
  },

  "commentTypes": {
    "runSummary":       "run-summary",
    "agentDiagnostics": "agent-diagnostics"
  },

  "runner": {
    "permissionMode": "acceptEdits"
  }
}
