{
  "_comment": "AISDLC workflow + harness config. State / category / override vocabularies are documented in .codex/skills/README.md (structural, not project-tunable).",

  "branches": {
    "prefix": "codex/",
    "protected": ["main", "master", "stage", "production"]
  },

  "repositories": {
    "application": "code"
  },

  "sourceControl": {
    "provider": "bitbucket",
    "baseUrl": "https://bitbucket.cambridgefx.com",
    "projectKey": "C",
    "repositorySlug": "code",
    "apiTokenEnv": "BITBUCKET_API_TOKEN"
  },

  "paths": {
    "feature":   "docs/features/{feature-slug}.md",
    "manifest":  "docs/ai-runs/{feature-slug}/manifest.yaml",
    "runs":      "docs/ai-runs/{feature-slug}/{story-id}/",
    "worktrees": ".worktrees/{story-id}/"
  },

  "caps": {
    "tddAttempts":          3,
    "diffFiles":            80,
    "diffLines":            3000,
    "perStoryWallClockSec": 3600,
    "afk": {
      "maxFlows":     10,
      "wallClockSec": 300
    }
  },

  "commentTypes": {
    "runSummary":       "run-summary",
    "agentDiagnostics": "agent-diagnostics"
  },

  "runner": {
    "sandboxMode": "workspace-write",
    "approvalPolicy": "on-request",
    "model": null
  }
}
